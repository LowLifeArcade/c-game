{
    "name": "pilgrim-of-the-thorn-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "npm run sync:assets && vite",
        "build": "npm run sync:assets && tsc -b && vite build",
        "build:dev": "CLOUDFLARE_ENV=dev npm run build",
        "preview": "vite preview",
        "sync:assets": "node scripts/sync-assets.mjs",
        "types": "wrangler types --env-file .env.example --strict-vars false",
        "db:migrate:local": "wrangler d1 migrations apply pilgrim-of-the-thorn-sales --local",
        "db:migrate:remote": "wrangler d1 migrations apply pilgrim-of-the-thorn-sales --remote",
        "build:game": "cd .. && make package-macos",
        "r2:upload:local": "node scripts/upload-download.mjs local",
        "r2:upload:dev": "node scripts/upload-download.mjs dev",
        "r2:upload:prod": "node scripts/upload-download.mjs prod",
        "deploy": "npm run deploy:prod",
        "deploy:dev": "npm run build:game && npm run build:dev && npm run r2:upload:dev && wrangler deploy",
        "deploy:prod": "npm run build:game && npm run build && npm run r2:upload:prod && wrangler deploy"
    },
    "dependencies": {
        "stripe": "^22.2.3"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.13.8",
        "@cloudflare/workers-types": "^4.20260620.0",
        "@types/node": "^24.0.3",
        "pngjs": "^7.0.0",
        "typescript": "^5.8.3",
        "vite": "^7.0.0",
        "wrangler": "^4.21.0"
    }
}
